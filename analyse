#!/usr/bin/env bash
# 24324533 - CITS4407 Assignment 2 - analyse
# Analyse the cleaned trending videos CSV file and print the required summary results.
# The script checks the input file first, then calculates frequency, average views,
# maximum dislikes, engagement rate, and sentiment rate.
file="$1"

# Must have exactly one argument
if test "$#" -ne 1
then
    echo "ERROR: No input CSV file provided"
    exit 1
fi

# Check file exists
if test ! -f "$file"
then
    echo "ERROR: Input file not found in the current directory"
    exit 1
fi

# Check that the input file has a .csv extension
if ! echo "$file" | grep '\.csv$' > /dev/null
then
    echo "ERROR: Input file expected in a CSV format"
    exit 1
fi

# Check file is not empty
if test ! -s "$file"
then
    echo "ERROR: Empty file provided"
    exit 1
fi

# Check header has exactly the expected columns.
header=$(head -n 1 "$file")

if test "$header" != "video_id,publish_date,views,likes,dislikes,comments_disabled"
then
    echo "ERROR: Invalid cleaned dataset format"
    exit 1
fi

# Check that each row has exactly 6 columns
bad_rows=$(awk -F',' 'NF != 6 {print; exit}' "$file")

if test -n "$bad_rows"
then
    echo "ERROR: Expected 6 columns in cleaned dataset"
    exit 1
fi
# Find the video_id that appears most often in the cleaned data.
video_counts=$(tail -n +2 "$file" | cut -d ',' -f1 | sort | uniq -c | sort -nr)
highest_count=$(echo "$video_counts" | head -n 1 | tr -s ' ' | cut -d ' ' -f2)
most_frequent=$(echo "$video_counts" | tr -s ' ' | grep "^ $highest_count " | cut -d ' ' -f3 | paste -sd ', ' -)

echo "Most frequent video, ID: $most_frequent"

# Calculate the mean number of views to two decimal places.
mean_views=$(tail -n +2 "$file" | awk -F',' '{total += $3; count += 1} END {printf "%.2f", total / count}')

echo "Mean number of views: $mean_views"

# Find the video_id with the highest number of dislikes.
dislike_rows=$(tail -n +2 "$file" | sort -t',' -k5 -nr)
max_dislike_value=$(echo "$dislike_rows" | head -n 1 | cut -d ',' -f5)
max_dislikes=$(echo "$dislike_rows" | awk -F',' -v max="$max_dislike_value" '$5 == max {print $1}' | paste -sd ', ' -)

echo "Max dislikes video, ID: $max_dislikes"

# Find the video with the highest engagement rate: (likes + dislikes) / views.
engagement_rows=$(tail -n +2 "$file" | awk -F',' '
{
    rate = ($4 + $5) / $3
    print $1 "," $2 "," rate
}
' | sort -t',' -k3 -nr)

max_engagement_rate=$(echo "$engagement_rows" | head -n 1 | cut -d ',' -f3)
highest_engagement=$(echo "$engagement_rows" | awk -F',' -v max="$max_engagement_rate" '$3 == max {print $1 ", dated: " $2}' | paste -sd ';' -)

echo "Highest engagement rate video, ID: $highest_engagement"

# Find the video with the lowest net sentiment rate: (likes - dislikes) / views.
sentiment_rows=$(tail -n +2 "$file" | awk -F',' '
{
    rate = ($4 - $5) / $3
    print $1 "," $2 "," rate
}
' | sort -t',' -k3 -n)

min_sentiment_rate=$(echo "$sentiment_rows" | head -n 1 | cut -d ',' -f3)
lowest_sentiment=$(echo "$sentiment_rows" | awk -F',' -v min="$min_sentiment_rate" '$3 == min {print $1 ", dated: " $2}' | paste -sd ';' -)

echo "Least sentiment rate video, ID: $lowest_sentiment"